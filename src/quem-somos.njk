<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quem somos — Wellbie</title>
<meta name="description" content="Por que a Wellbie existe: a história da fundadora Priscila Barroso e a missão de tornar o sono uma prática de autocuidado.">
<link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
<link rel="icon" type="image/png" href="{{ '/assets/favicon.png' | url }}">
<link rel="apple-touch-icon" href="{{ '/assets/favicon.png' | url }}">
<style>
  :root{
    --creme:#EDEAE6; --nude:#C9BC9C; --azul-claro:#C3CDD4; --azul:#3C5668;
    --verde-medio:#8C9670; --verde:#3C4422; --cinza:#272723; --branco:#FFF;
    --serif:Georgia,'Times New Roman',serif;
    --sans:-apple-system,'Helvetica Neue',Arial,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--creme);color:var(--cinza);font-family:var(--sans);font-size:16px;line-height:1.6;}

  nav{background:var(--verde-medio);display:flex;justify-content:space-between;align-items:center;padding:20px 64px;}
  nav .logo{display:flex;align-items:center;}
  .logo-img{height:56px;width:auto;display:block;}
  .logo-light{filter:brightness(0) invert(1);}
  nav ul{list-style:none;display:flex;gap:32px;}
  nav ul li a{font-family:var(--sans);font-size:13px;font-weight:400;color:var(--creme);text-decoration:none;letter-spacing:1px;text-transform:uppercase;opacity:.8;}

  .eyebrow{font-size:11px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--verde-medio);margin-bottom:30px;}

  .manifesto{background:var(--creme);text-align:center;padding:120px 56px 104px;display:flex;flex-direction:column;align-items:center;}
  .manifesto h1{font-family:var(--serif);font-size:52px;font-weight:400;line-height:1.12;color:var(--cinza);max-width:820px;margin-bottom:28px;text-wrap:balance;}
  .manifesto h1 em{font-style:italic;color:var(--verde);}
  .manifesto p{font-size:19px;font-weight:300;line-height:1.6;color:var(--cinza);opacity:.72;max-width:560px;}
  .m-rule{width:56px;height:1px;background:var(--nude);margin-top:44px;}

  .founder{display:grid;grid-template-columns:1fr 1fr;background:var(--cinza);align-items:stretch;}
  .founder-img{min-height:560px;line-height:0;}
  .founder-img img{width:100%;height:100%;object-fit:cover;object-position:center;display:block;}
  .founder-text{padding:84px 56px;display:flex;flex-direction:column;justify-content:center;}
  .founder-text .eyebrow{color:var(--nude);}
  .founder-text h2{font-family:var(--serif);font-size:36px;font-weight:400;line-height:1.16;color:var(--creme);margin-bottom:26px;text-wrap:balance;}
  .founder-text p{font-size:16.5px;line-height:1.85;color:var(--creme);max-width:470px;margin-bottom:18px;}
  .founder-text p strong{color:var(--branco);font-weight:600;}
  .founder-sign{font-family:var(--serif);font-style:italic;font-size:17px;color:var(--nude);margin-top:8px;}
  .divider{width:48px;height:1px;background:var(--nude);margin:8px 0 22px;}

  .belief{background:var(--verde-medio);text-align:center;padding:92px 56px;display:flex;flex-direction:column;align-items:center;}
  .belief .eyebrow{color:var(--creme);opacity:.55;}
  .belief h2{font-family:var(--serif);font-size:38px;font-weight:400;line-height:1.14;color:var(--creme);max-width:640px;margin-bottom:32px;text-wrap:balance;}
  .pills{display:flex;align-items:center;justify-content:center;margin-bottom:32px;flex-wrap:wrap;}
  .pill{font-family:var(--serif);font-style:italic;font-size:24px;color:var(--creme);padding:0 26px;}
  .pill+.pill{border-left:1px solid rgba(237,234,230,.45);}
  .belief p{font-size:17px;line-height:1.75;color:var(--creme);max-width:520px;}

  .close{background:var(--creme);text-align:center;padding:104px 56px;display:flex;flex-direction:column;align-items:center;}
  .close .eyebrow{color:var(--verde-medio);}
  .close h2{font-family:var(--serif);font-size:54px;font-weight:400;line-height:1.06;color:var(--cinza);margin-bottom:20px;text-wrap:balance;max-width:720px;}
  .close p{font-size:18px;line-height:1.7;color:var(--cinza);opacity:.7;max-width:560px;margin-bottom:40px;}
  .btn{display:inline-block;padding:16px 44px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;background:var(--verde-medio);color:var(--creme);text-decoration:none;}

  footer{background:var(--verde-medio);padding:48px 64px;display:flex;justify-content:space-between;align-items:center;}
  .footer-contact{text-align:center;}
  .footer-contact-label{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--creme);opacity:.6;margin-bottom:6px;}
  .footer-contact-info{font-size:13px;color:var(--creme);opacity:.85;display:flex;flex-direction:column;gap:4px;align-items:center;}
  footer p{font-size:12px;color:var(--creme);opacity:.4;letter-spacing:1px;}
  .foot-right{text-align:right;}

  @media(max-width:820px){
    nav{flex-direction:column;gap:16px;padding:20px 20px;}
    nav .logo{justify-content:center;}
    nav ul{gap:22px;justify-content:center;}
    nav ul li a{font-size:11px;letter-spacing:.5px;white-space:nowrap;}
    .manifesto{padding:72px 24px 56px;}
    .manifesto h1{font-size:34px;}
    .manifesto p{font-size:17px;}
    .founder{grid-template-columns:1fr;}
    .founder-img{min-height:auto;order:-1;}
    .founder-text{padding:56px 24px;}
    .founder-text h2,.belief h2{font-size:28px;}
    .close h2{font-size:34px;}
    .belief,.close{padding:64px 24px;}
    .pill{font-size:20px;padding:6px 16px;}
    footer{flex-direction:column;gap:24px;text-align:center;padding:40px 24px;}
    .foot-right{text-align:center;}
  }
</style>
</head>
<body>

{%- set q = site.quem_somos -%}

<nav id="topo">
  <div class="logo">
    <a href="{{ '/' | url }}" aria-label="Página inicial"><img src="{{ site.footer.logo | url }}" alt="wellbie" class="logo-img logo-light"></a>
  </div>
  <ul>
    <li><a href="{{ '/quem-somos/' | url }}">Quem somos</a></li>
    <li><a href="{{ '/#produtos' | url }}">Produtos</a></li>
    <li><a href="{{ site.nav.links[2].url }}">Contato</a></li>
  </ul>
</nav>

<section class="manifesto">
  <p class="eyebrow">{{ q.manifesto_eyebrow }}</p>
  <h1>{{ q.manifesto_headline | safe }}</h1>
  <p>{{ q.manifesto_sub }}</p>
  <div class="m-rule"></div>
</section>

<section class="founder">
  <div class="founder-img">
    <picture>
      <source media="(max-width:820px)" srcset="{{ q.fundadora_foto_mobile | url }}">
      <img src="{{ q.fundadora_foto | url }}" alt="{{ q.fundadora_assinatura }}">
    </picture>
  </div>
  <div class="founder-text">
    <p class="eyebrow">{{ q.fundadora_eyebrow }}</p>
    <h2>{{ q.fundadora_headline | safe }}</h2>
    {% for par in q.fundadora_paragrafos %}<p>{{ par | safe }}</p>{% endfor %}
    <div class="divider"></div>
    <div class="founder-sign">{{ q.fundadora_assinatura }}</div>
  </div>
</section>

<section class="belief">
  <p class="eyebrow">{{ q.crencas_eyebrow }}</p>
  <h2>{{ q.crencas_headline | safe }}</h2>
  <div class="pills">
    {% for p in q.crencas_pilares %}<span class="pill">{{ p }}</span>{% endfor %}
  </div>
  <p>{{ q.crencas_texto }}</p>
</section>

<section class="close">
  <p class="eyebrow">{{ q.cta_eyebrow }}</p>
  <h2>{{ q.cta_headline | safe }}</h2>
  <p>{{ q.cta_sub }}</p>
  <a href="{{ q.cta_button_url | url }}" class="btn">{{ q.cta_button_label }} →</a>
</section>

<footer>
  <div class="logo">
    <img src="{{ site.footer.logo | url }}" alt="wellbie" class="logo-img logo-light">
  </div>
  <div class="footer-contact">
    <p class="footer-contact-label">{{ site.footer.contact_label }}</p>
    <div class="footer-contact-info">
      <span>{{ site.footer.email }}</span>
      <span>{{ site.footer.phone }}</span>
    </div>
  </div>
  <div class="foot-right">
    <p>{{ site.footer.copyright }}</p>
    <p style="margin-top:6px;">{{ site.footer.razao_social }}</p>
    <p style="margin-top:2px;">{{ site.footer.cnpj }}</p>
  </div>
</footer>

</body>
</html>
