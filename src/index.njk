<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wellbie — Sono com qualidade</title>
<meta name="description" content="wellbie — suplementos pensados para quem leva o sono a sério. Melatonina e Magic5.">
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<style>
  :root {
    --creme:       #EDEAE6;
    --nude:        #C9BC9C;
    --azul-claro:  #C3CDD4;
    --azul:        #3C5668;
    --verde-medio: #8C9670;
    --verde:       #3C4422;
    --cinza:       #272723;
    --branco:      #FFFFFF;
    --serif: Georgia, 'Times New Roman', serif;
    --sans:  -apple-system, 'Helvetica Neue', Arial, sans-serif;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { overflow-anchor: none; scroll-behavior: smooth; }
  body { background: var(--creme); color: var(--cinza); font-family: var(--sans); font-size: 16px; line-height: 1.6; }

  nav { background: var(--verde-medio); display: flex; justify-content: space-between; align-items: center; padding: 20px 64px; }
  .logo { display: flex; align-items: center; }
  .logo-img { height: 56px; width: auto; display: block; }
  .logo-light { filter: brightness(0) invert(1); }
  nav ul { list-style: none; display: flex; gap: 32px; }
  nav ul li a { font-family: var(--sans); font-size: 13px; font-weight: 400; color: var(--creme); text-decoration: none; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8; }

  .hero { position: relative; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; min-height: 88vh; background: var(--creme); }
  .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: left center; z-index: 0; }
  .hero-empty { position: relative; z-index: 1; }
  .hero-text { position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: center; padding: 96px 64px; background: rgba(237,234,230,0.55); backdrop-filter: blur(2px); }
  .hero-tag { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--verde); opacity: 0.8; margin-bottom: 32px; }
  .hero-headline { font-family: var(--serif); font-size: 64px; font-weight: 400; color: var(--cinza); line-height: 1.05; margin-bottom: 28px; }
  .hero-sub { font-family: var(--sans); font-size: 17px; font-weight: 300; color: var(--cinza); opacity: 0.75; line-height: 1.6; max-width: 380px; margin-bottom: 48px; }
  .btn-scroll { display: inline-flex; align-items: center; gap: 10px; font-family: var(--sans); font-size: 13px; font-weight: 500; color: var(--cinza); letter-spacing: 2px; text-transform: uppercase; text-decoration: none; border-bottom: 1px solid var(--cinza); padding-bottom: 4px; width: fit-content; opacity: 0.7; }

  section { padding: 96px 64px; }
  .section-tag { font-family: var(--sans); font-size: 10px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--verde-medio); margin-bottom: 24px; }

  .problema { position: relative; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; padding: 0; background: var(--cinza); }
  .problema-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 70% center; z-index: 0; }
  .problema-empty { position: relative; z-index: 1; }
  .problema-text { position: relative; z-index: 1; padding: 96px 64px; display: flex; flex-direction: column; justify-content: center; background: rgba(39,39,35,0.52); backdrop-filter: blur(3px); }
  .problema-headline { font-family: var(--serif); font-size: 48px; font-weight: 400; color: var(--creme); line-height: 1.1; margin-bottom: 24px; }
  .problema-sub { font-family: var(--serif); font-style: italic; font-size: 22px; color: var(--nude); line-height: 1.4; margin-bottom: 32px; }
  .problema-intro { font-size: 16px; color: var(--creme); opacity: 0.82; line-height: 1.7; margin-bottom: 36px; max-width: 480px; }
  .problema-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; max-width: 480px; }
  .problema-list li { position: relative; padding-left: 22px; font-size: 15px; color: var(--creme); opacity: 0.85; line-height: 1.55; }
  .problema-list li::before { content: '•'; position: absolute; left: 2px; top: -1px; color: var(--nude); font-size: 18px; }
  .problema-list li strong { font-weight: 700; opacity: 1; }
  .problema-fecho { font-family: var(--serif); font-size: 19px; font-style: italic; color: var(--nude); line-height: 1.6; margin-bottom: 36px; max-width: 480px; }
  .btn-ebook { display: inline-block; align-self: flex-start; padding: 14px 34px; font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; background: var(--nude); color: var(--cinza); text-decoration: none; transition: opacity 0.2s; }
  .btn-ebook:hover { opacity: 0.85; }
  .divider { width: 48px; height: 1px; background: var(--nude); margin: 40px 0; }

  .melatonina { background: var(--azul-claro); display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; padding: 0; }
  .melatonina .produto-text { padding: 96px 64px; display: flex; flex-direction: column; justify-content: center; }
  .melatonina .produto-image { height: 100%; min-height: 560px; }
  .produto-image { height: 560px; display: flex; align-items: center; justify-content: center; }
  .produto-headline { font-family: var(--serif); font-size: 52px; font-weight: 400; color: var(--cinza); line-height: 1.05; margin-bottom: 20px; }
  .produto-sub { font-size: 16px; color: var(--cinza); opacity: 0.75; line-height: 1.7; margin-bottom: 32px; max-width: 420px; }
  .produto-specs { display: flex; flex-direction: column; gap: 8px; margin-bottom: 40px; }
  .spec { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--azul); display: flex; align-items: center; gap: 10px; }
  .spec::before { content: '·'; font-size: 18px; color: var(--azul); }
  .btn-primary { display: inline-block; width: 160px; padding: 12px 0; line-height: 1; font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; text-align: center; background: var(--azul); color: var(--branco); text-decoration: none; border: none; cursor: pointer; }
  .btn-verde { background: var(--verde-medio); color: var(--branco); }

  .magic5 { background: var(--creme); display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; padding: 0; }
  .magic5 .produto-text { padding: 96px 64px; display: flex; flex-direction: column; justify-content: center; }
  .magic5 .produto-image { height: 100%; min-height: 560px; }

  .kit { background: var(--cinza); display: flex; flex-direction: column; padding: 0; }
  .kit-text { padding: 112px 64px 56px; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .kit-image { position: relative; overflow: hidden; line-height: 0; }
  .kit-image img { width: 100%; display: block; object-fit: cover; }
  .kit-image .btn-kit { position: absolute; bottom: 48px; left: 50%; transform: translateX(-50%); white-space: nowrap; }
  .kit .section-tag { color: var(--nude); }
  .kit-headline { font-family: var(--serif); font-size: 56px; font-weight: 400; color: var(--creme); line-height: 1.1; margin-bottom: 16px; }
  .kit-sub { font-size: 17px; color: var(--nude); max-width: 520px; margin-bottom: 48px; line-height: 1.7; }
  .kit-items { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }
  .kit-item { background: rgba(237,234,230,0.08); border: 1px solid rgba(237,234,230,0.2); padding: 16px 24px; font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--nude); }
  .btn-kit { display: inline-block; padding: 18px 56px; font-family: var(--sans); font-size: 13px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; background: var(--nude); color: var(--cinza); text-decoration: none; cursor: pointer; }

  .social { position: relative; overflow: hidden; background: var(--verde-medio); transition: background 0.8s ease; padding: 0; }
  .depo-slider { position: relative; min-height: 520px; }
  .depo-slide { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 80px 180px; opacity: 0; transition: opacity 0.9s ease; pointer-events: none; gap: 0; }
  .depo-slide.active { opacity: 1; pointer-events: auto; }
  .depo-eyebrow { font-family: var(--sans); font-size: 10px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; display: block; margin-bottom: 24px; }
  .depo-quote { font-family: var(--serif); font-size: 30px; font-weight: 400; line-height: 1.55; margin-bottom: 28px; max-width: 760px; }
  .depo-autor { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; }
  .depo-light .depo-eyebrow { color: var(--creme); opacity: 0.55; }
  .depo-light .depo-quote   { color: var(--creme); }
  .depo-light .depo-autor   { color: var(--creme); opacity: 0.65; }
  .depo-dark .depo-eyebrow  { color: var(--cinza); opacity: 0.45; }
  .depo-dark .depo-quote    { color: var(--cinza); }
  .depo-dark .depo-autor    { color: var(--cinza); opacity: 0.55; }
  .social-controls { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 24px 64px 48px; }
  .depo-dots { display: flex; gap: 10px; align-items: center; }
  .depo-dot { width: 6px; height: 6px; border-radius: 50%; border: none; cursor: pointer; padding: 0; background: var(--dot-color, rgba(237,234,230,0.35)); transition: all 0.35s ease; }
  .depo-dot.active { width: 22px; border-radius: 3px; background: var(--dot-active, rgba(237,234,230,0.9)); }
  .depo-bar-track { width: 180px; height: 1px; background: var(--dot-color, rgba(237,234,230,0.2)); }
  .depo-bar-fill { height: 100%; width: 0%; background: var(--dot-active, rgba(237,234,230,0.75)); transition: width 5s linear; }

  .cta-final { background: var(--creme); text-align: center; padding: 112px 64px; }
  .cta-headline { font-family: var(--serif); font-size: 72px; font-weight: 400; color: var(--cinza); line-height: 1.0; margin-bottom: 12px; }
  .cta-sub { font-size: 17px; color: var(--cinza); opacity: 0.6; margin-bottom: 64px; }
  .produtos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; max-width: 960px; margin: 0 auto 48px; }
  .produto-card { background: var(--verde-medio); padding: 48px 32px; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .produto-card.card-mel { background: var(--azul); }
  .produto-card.card-kit { background: var(--cinza); }
  .produto-card-img { width: 180px; height: 270px; overflow: hidden; }
  .produto-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .produto-card-name { font-family: var(--serif); font-size: 22px; color: var(--creme); }
  .produto-card-btn { display: block; width: 100%; padding: 12px; line-height: 1; font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; background: rgba(237,234,230,0.15); color: var(--creme); text-decoration: none; border: 1px solid rgba(237,234,230,0.3); text-align: center; cursor: pointer; }
  .cta-info { display: flex; justify-content: center; gap: 48px; font-size: 12px; color: var(--cinza); opacity: 0.5; letter-spacing: 1px; text-transform: uppercase; }

  footer { background: var(--verde-medio); padding: 48px 64px; display: flex; justify-content: space-between; align-items: center; }
  .footer-contact { text-align: center; }
  .footer-contact-label { font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--creme); opacity: 0.6; margin-bottom: 6px; }
  .footer-contact-info { font-size: 13px; color: var(--creme); opacity: 0.85; display: flex; flex-direction: column; gap: 4px; align-items: center; }
  footer p { font-size: 12px; color: var(--creme); opacity: 0.4; letter-spacing: 1px; }

  @media (max-width: 820px) {
    /* NAV — logo centralizado em cima, links numa linha só embaixo */
    nav { flex-direction: column; gap: 16px; padding: 20px 20px; }
    nav .logo { justify-content: center; }
    nav ul { gap: 22px; justify-content: center; flex-wrap: nowrap; }
    nav ul li a { font-size: 11px; letter-spacing: 0.5px; white-space: nowrap; }

    /* HERO — mulher visível ao fundo, overlay mais leve e sem blur */
    .hero { grid-template-columns: 1fr; min-height: 78vh; }
    .hero-empty { display: none; }
    .hero-bg { object-position: 15% center; }
    .hero-headline { font-size: 40px; }
    .hero-sub { font-size: 16px; }
    .hero-text { padding: 56px 24px; background: rgba(237,234,230,0.38); backdrop-filter: none; -webkit-backdrop-filter: none; }

    /* PRODUTOS / PROBLEMA — vídeo em cima; imagem do problema mostrando o rosto */
    .problema, .melatonina, .magic5 { grid-template-columns: 1fr; }
    .problema-bg { object-position: 60% center; }
    .melatonina .produto-image, .magic5 .produto-image { min-height: 320px; }
    .problema-text, .melatonina .produto-text, .magic5 .produto-text { padding: 56px 24px; }
    .problema-text { backdrop-filter: none; -webkit-backdrop-filter: none; }
    .problema-empty { display: none; }
    .melatonina .produto-image, .magic5 .produto-image { order: -1; }
    .problema-headline, .produto-headline { font-size: 34px; }

    /* KIT — imagem com altura definida, chips menores, botão reposicionado */
    .kit-text { padding: 56px 24px 36px; }
    .kit-headline { font-size: 32px; }
    .kit-sub { font-size: 15px; margin-bottom: 32px; }
    .kit-items { gap: 10px; margin-bottom: 8px; }
    .kit-item { padding: 11px 16px; font-size: 11px; }
    .kit-image { min-height: 280px; }
    .kit-image img { height: 280px; }
    .kit-image .btn-kit { bottom: 24px; padding: 14px 34px; font-size: 12px; }

    /* DEPOIMENTOS / CTA / FOOTER */
    .depo-slide { padding: 56px 28px; }
    .depo-quote { font-size: 21px; }
    .cta-headline { font-size: 46px; }
    .cta-final { padding: 64px 24px; }
    .produtos-grid { grid-template-columns: 1fr; max-width: 320px; }
    .cta-info { flex-direction: column; gap: 8px; }
    footer { flex-direction: column; gap: 24px; padding: 40px 24px; text-align: center; }
    footer > div[style*="right"] { text-align: center !important; }
  }
</style>
</head>
<body>

<nav id="topo">
  <div class="logo">
    <a href="#topo" aria-label="Voltar ao topo"><img src="{{ site.footer.logo }}" alt="wellbie" class="logo-img logo-light"></a>
  </div>
  <ul>
    {% for link in site.nav.links %}<li><a href="{{ link.url }}">{{ link.label }}</a></li>{% endfor %}
  </ul>
</nav>

<section class="hero" style="padding:0;">
  <img class="hero-bg" src="{{ site.hero.image }}" alt="Mulher acordando descansada">
  <div class="hero-empty"></div>
  <div class="hero-text">
    <p class="hero-tag">{{ site.hero.tag }}</p>
    <h1 class="hero-headline">{{ site.hero.headline | safe }}</h1>
    <p class="hero-sub">{{ site.hero.sub }}</p>
    <a href="{{ site.hero.button_url }}" class="btn-scroll">{{ site.hero.button_label }}</a>
  </div>
</section>

<section class="problema">
  <img class="problema-bg" src="{{ site.problema.image }}" alt="Pessoa com insônia">
  <div class="problema-text">
    <p class="section-tag" style="color:var(--nude);">{{ site.problema.tag }}</p>
    <h2 class="problema-headline">{{ site.problema.headline | safe }}</h2>
    <p class="problema-sub">{{ site.problema.sub }}</p>
    <p class="problema-intro">{{ site.problema.intro }}</p>
    <ul class="problema-list">
      {% for item in site.problema.bullets %}
      <li><strong>{{ item.destaque }}</strong> {{ item.texto }}</li>
      {% endfor %}
    </ul>
    <p class="problema-fecho">{{ site.problema.fecho }}</p>
    {% if site.problema.ebook_label %}
    <a class="btn-ebook" href="{{ site.problema.ebook_url }}">{{ site.problema.ebook_label }}</a>
    {% endif %}
  </div>
  <div class="problema-empty"></div>
</section>

<section class="melatonina" id="produtos">
  <div class="produto-image mel-bg" style="padding:0; overflow:hidden; background:var(--azul);">
    <video autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover; display:block;">
      <source src="{{ site.melatonina.video }}" type="video/mp4">
    </video>
  </div>
  <div class="produto-text">
    <p class="section-tag" style="color:var(--azul);">{{ site.melatonina.tag }}</p>
    <h2 class="produto-headline">{{ site.melatonina.headline | safe }}</h2>
    <p class="produto-sub">{{ site.melatonina.sub }}</p>
    <div class="produto-specs">
      {% for spec in site.melatonina.specs %}<span class="spec">{{ spec }}</span>{% endfor %}
    </div>
    <a href="{{ site.melatonina.button_url }}" class="btn-primary">{{ site.melatonina.button_label }}</a>
  </div>
</section>

<section class="magic5">
  <div class="produto-text">
    <p class="section-tag" style="color:var(--verde);">{{ site.magic5.tag }}</p>
    <h2 class="produto-headline">{{ site.magic5.headline | safe }}</h2>
    <p class="produto-sub">{{ site.magic5.sub }}</p>
    <div class="produto-specs">
      {% for spec in site.magic5.specs %}<span class="spec" style="color:var(--verde);">{{ spec }}</span>{% endfor %}
    </div>
    <a href="{{ site.magic5.button_url }}" class="btn-primary btn-verde">{{ site.magic5.button_label }}</a>
  </div>
  <div class="produto-image mag-bg" style="padding:0; overflow:hidden; background:var(--cinza);">
    <video autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover; display:block;">
      <source src="{{ site.magic5.video }}" type="video/mp4">
    </video>
  </div>
</section>

<section class="kit">
  <div class="kit-text">
    <p class="section-tag">{{ site.kit.tag }}</p>
    <h2 class="kit-headline">{{ site.kit.headline | safe }}</h2>
    <p class="kit-sub">{{ site.kit.sub }}</p>
    <div class="kit-items">
      {% for item in site.kit.items %}<div class="kit-item">{{ item }}</div>{% endfor %}
    </div>
  </div>
  <div class="kit-image">
    <img src="{{ site.kit.image }}" alt="Kit Ritual do Sono wellbie">
    <a href="{{ site.kit.button_url }}" class="btn-kit">{{ site.kit.button_label }}</a>
  </div>
</section>

<section class="social" id="social-section">
  <div class="depo-slider">
    {% for slide in site.depoimentos.slides %}
    <div class="depo-slide {% if loop.first %}active {% endif %}depo-light" data-bg="#8C9670" data-scheme="light">
      <span class="depo-eyebrow">{{ site.depoimentos.eyebrow }}</span>
      <p class="depo-quote">{{ slide.quote }}</p>
      <p class="depo-autor">{{ slide.autor }}</p>
    </div>
    {% endfor %}
  </div>
  <div class="social-controls">
    <div class="depo-dots">
      {% for slide in site.depoimentos.slides %}<button class="depo-dot {% if loop.first %}active{% endif %}" data-index="{{ loop.index0 }}"></button>{% endfor %}
    </div>
    <div class="depo-bar-track"><div class="depo-bar-fill"></div></div>
  </div>
</section>

<section class="cta-final" id="contato">
  <h2 class="cta-headline">{{ site.cta.headline | safe }}</h2>
  <p class="cta-sub">{{ site.cta.sub }}</p>
  <div class="produtos-grid">
    {% for p in site.cta.produtos %}
    <div class="produto-card{% if loop.index0 == 0 %} card-mel{% elif loop.index0 == 2 %} card-kit{% endif %}">
      <div class="produto-card-img"><img src="{{ p.image }}" alt="{{ p.name }} wellbie"></div>
      <div class="produto-card-name">{{ p.name }}</div>
      <a href="{{ p.button_url }}" class="produto-card-btn">{{ p.button_label }}</a>
    </div>
    {% endfor %}
  </div>
  <div class="cta-info">
    {% for badge in site.cta.info %}<span>{{ badge }}</span>{% endfor %}
  </div>
</section>

<footer>
  <div class="logo">
    <img src="{{ site.footer.logo }}" alt="wellbie" class="logo-img logo-light">
  </div>
  <div class="footer-contact">
    <p class="footer-contact-label">{{ site.footer.contact_label }}</p>
    <div class="footer-contact-info">
      <span>{{ site.footer.email }}</span>
      <span>{{ site.footer.phone }}</span>
    </div>
  </div>
  <div style="text-align:right;">
    <p>{{ site.footer.copyright }}</p>
    <p style="margin-top:6px;">{{ site.footer.razao_social }}</p>
    <p style="margin-top:2px;">{{ site.footer.cnpj }}</p>
  </div>
</footer>

<script>
(function () {
  const section  = document.getElementById('social-section');
  const slides   = section.querySelectorAll('.depo-slide');
  const dots     = section.querySelectorAll('.depo-dot');
  const barFill  = section.querySelector('.depo-bar-fill');
  const DURATION = 5000;
  let current = 0;
  let timer;
  const light = { '--dot-color': 'rgba(237,234,230,0.35)', '--dot-active': 'rgba(237,234,230,0.9)' };
  function goTo(i) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (i + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
    section.style.background = slides[current].dataset.bg;
    Object.entries(light).forEach(([k, v]) => section.style.setProperty(k, v));
    barFill.style.transition = 'none';
    barFill.style.width = '0%';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      barFill.style.transition = `width ${DURATION}ms linear`;
      barFill.style.width = '100%';
    }));
  }
  function startTimer() { clearInterval(timer); timer = setInterval(() => goTo(current + 1), DURATION); }
  dots.forEach(dot => { dot.addEventListener('click', () => { goTo(parseInt(dot.dataset.index)); startTimer(); }); });
  goTo(0);
  startTimer();
})();
</script>

<script>
  // Login do editor: ao confirmar o convite/login, leva direto ao painel /admin
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
